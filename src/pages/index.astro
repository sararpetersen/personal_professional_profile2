            <p class="font-bold">Creative Cloud:</p>
            <ol>
              <li>1. Adobe Photoshop</li>
              <li>2. Adobe Illustrator</li>
              <li>3. Adobe Lightroom</li>
              <li>4. Adobe Premiere Pro</li>
            </ol>
          </div>
        </div>
        <div class="icon-wrapper">
          <div
            role="img"
            aria-label="Claude"
            class="claude-icon-frame max-w-full w-[70px] h-[70px] sm:w-[90px] sm:h-[90px] flex items-center justify-center"
          >
            <img id="claude" class="w-full h-full transition duration-300" src="/other/claude-logo.svg" alt="Logo of Claude AI" />
          </div>
          <div class="tooltip absolute rounded p-2 mt-1">
            <p class="font-bold">Claude AI:</p>
            <ol>
              <li>1. Coding assistance</li>
              <li>2. Debugging</li>
              <li>3. Content drafting</li>
              <li>4. Documentation</li>
            </ol>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION: Selected Cases -->
  <div id="projects" class="projects_container pt-20 md:pt-60">
    <div class="flex justify-center">
      <div class="container mx-auto px-4 py-4">
        <h3 class="section-heading text-h3-mobile md:text-h3-desktop text-left pb-6 text-pale-50">Selected cases</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
