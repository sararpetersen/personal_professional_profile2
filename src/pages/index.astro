      <p class="skill-device-note">Tooltips are available on desktop only.</p>
    </div>
    <div class="icon-container">
      <!-- Skill icon row 1 -->
      <div class="app_icons1 flex flex-wrap justify-center gap-6 mb-8 xl:gap-20">
        <div class="icon-wrapper top-tooltip">
          <img
            id="figma"
            class="max-w-full w-[70px] h-[70px] sm:w-[90px] sm:h-[90px] transition duration-300"
            src="/other/figma-logo.webp"
            alt="Logo of Figma"
          />
          <div class="tooltip absolute rounded p-2 mt-1">
            <p class="font-bold">Figma:</p>
            <ol>
              <li>1. Styles</li>
              <li>2. Components</li>
              <li>3. Design-systems</li>
              <li>4. Wireframes</li>
              <li>5. Prototypes</li>
            </ol>
          </div>
        </div>
        <div class="icon-wrapper top-tooltip">
          <img
            id="vscode"
            class="max-w-full w-[70px] h-[70px] sm:w-[90px] sm:h-[90px] transition duration-300"
            src="/other/vs_code.webp"
            alt="Logo of Visual Studio Code"
          />
          <div class="tooltip absolute rounded p-2 mt-1">
            <p class="font-bold">Visual Studio Code:</p>
            <ol>
              <li>1. HTML</li>
              <li>2. CSS</li>
              <li>3. JavaScript</li>
              <li>4. Astro</li>
