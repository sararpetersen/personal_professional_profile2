  <!-- SECTION: Page Interactions -->
  <script>
    const initHomePageInteractions = () => {
      const sections = document.querySelectorAll(".fade-in-section");

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.12 },
        );

        sections.forEach((section) => observer.observe(section));
      } else {
        // No IntersectionObserver support: nothing will ever trigger a reveal, so just show
        // the content instead of leaving it invisible forever.
        sections.forEach((section) => section.classList.add("is-visible"));
      }

      // Staggered fadeInUp entrance, forEach over each group with an increasing delay per item —
      // same idea as the portfolio's registerInView helper, minus the motion.js/animate.css
      // dependency: plain CSS transitions driven by a --stagger-delay custom property.
      // Skill icons and social links are intentionally left out of the stagger set since they
      // already have their own hover :transform, and stacking an entrance transform on top of
      // that caused a flicker when hovered mid-animation. Case cards get a wrapper element
      // (.case-stagger) instead of staggering .case-card itself, for the same reason.
      const staggerGroups: NodeListOf<Element>[] = [
        document.querySelectorAll("#info, #pfp"),
        document.querySelectorAll(".timeline-card"),
        document.querySelectorAll(".case-stagger"),
      ];

      const staggerObserver =
        "IntersectionObserver" in window
          ? new IntersectionObserver(
              (entries) => {
                for (const entry of entries) {
                  if (entry.isIntersecting) {
                    entry.target.classList.add("is-visible");
                    staggerObserver?.unobserve(entry.target);
                  }
                }
              },
              { rootMargin: "0px 0px -8% 0px", threshold: 0.12 },
            )
          : null;

      staggerGroups.forEach((group) => {
        group.forEach((item, index) => {
          item.classList.add("stagger-item");
          (item as HTMLElement).style.setProperty("--stagger-delay", `${Math.min(index * 80, 480)}ms`);
          if (staggerObserver) {
            staggerObserver.observe(item);
          } else {
            item.classList.add("is-visible");
          }
        });
      });

      const iconWrappers = document.querySelectorAll(".icon-wrapper");
      iconWrappers.forEach((wrapper) => {
        wrapper.addEventListener("click", (event) => {
          const isActive = wrapper.classList.contains("tooltip-active");
          iconWrappers.forEach((w) => w.classList.remove("tooltip-active"));
          if (!isActive) wrapper.classList.add("tooltip-active");
          event.stopPropagation();
        });
      });
      document.addEventListener("click", () => {
        iconWrappers.forEach((w) => w.classList.remove("tooltip-active"));
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHomePageInteractions, { once: true });
    } else {
      initHomePageInteractions();
    }
  </script>
