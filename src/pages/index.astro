  <!-- SECTION: Page Interactions -->
  <script>
    import { inView } from "motion";

    document.addEventListener("DOMContentLoaded", () => {
      const reduceMotion = document.body.classList.contains("reduce-motion") || window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const isMobileViewport = window.matchMedia("(max-width: 767px)").matches;

      if (!reduceMotion) {
        const heroTitles = document.querySelectorAll<HTMLElement>(".hero-title-entrance");
        heroTitles.forEach((title, index) => {
          let stop = () => {};
          stop = inView(title, () => {
            const delayMs = 180 + index * 260;
            title.classList.add("animate__animated", "animate__fadeInUp");
            title.style.animationDelay = `${isMobileViewport ? Math.min(delayMs, 320) : delayMs}ms`;
            title.style.animationDuration = isMobileViewport ? "1.25s" : "1.85s";
            title.style.animationFillMode = "both";
            stop();
          });
        });

        const heroEntrance = document.querySelector<HTMLElement>(".hero-image-entrance");
        const heroImage = document.querySelector<HTMLElement>(".hero-image-wrap");
        if (heroEntrance && heroImage) {
          let stopHeroImage = () => {};
          stopHeroImage = inView(heroEntrance, () => {
            heroEntrance.classList.add("animate__animated", "animate__fadeInUp");
            heroEntrance.style.animationDelay = isMobileViewport ? "260ms" : "420ms";
