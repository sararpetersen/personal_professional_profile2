---

---

<header id="header" class="fixed w-full p-4 md:px-16 z-[99] bg-gray-800">
  <div x-data="{ showmenu: false }">
    <div id="navbar" class="flex flex-row justify-between items-center">
      <div id="logo">
        <a href="#top" aria-label="Go to top of page"
          ><img
            src="/illustrations/logo-srp-white.svg"
            alt="Logo for my website, with three of my initials (white)"
            aria-hidden="true"
            class="h-16 transition duration-300 ease-out group-hover:-translate-y-[2px] group-hover:scale-[1.02]"
            width="64"
            height="64"
            loading="eager"
          /></a
        >
      </div>
      <nav id="desktopmenu" aria-label="Main navigation" class="hidden lg:block text-pale-50">
        <ul class="flex items-center gap-8">
          <li><a href="#info" class="nav-link">Who am I?</a></li>
          <li><a href="#timeline" class="nav-link">Timeline</a></li>
          <li><a href="#skills" class="nav-link">Skills</a></li>
          <li><a href="#projects" class="nav-link">Selected Cases</a></li>
          <li><a href="#contact" class="nav-link">Contact</a></li>
        </ul>
      </nav>
      <button
        id="burgermenu"
        aria-label="Toggle mobile menu"
        aria-controls="mobilmenu"
        x-bind:aria-expanded="showmenu ? 'true' : 'false'"
        class="lg:hidden"
        x-on:click="showmenu = !showmenu"
      >
        <svg
          x-show="!showmenu"
          x-cloak
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="burger-icon size-8 transition duration-300"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
        <svg
          x-show="showmenu"
          x-cloak
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="burger-icon size-8 transition duration-300"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <nav
      id="mobilmenu"
      aria-label="Mobile navigation"
      class="flex flex-col content-center pt-4"
      x-show="showmenu"
      x-cloak
      x-transition
      x-on:click="showmenu = false"
      x-on:click.outside="showmenu = false"
      x-on:keydown.escape.window="showmenu = false"
    >
      <ul>
        <li class="mobile-nav-item text-center py-3 transition duration-300">
          <a href="#info" class="mobile-nav-link">Who am I?</a>
        </li>
        <li class="mobile-nav-item text-center py-3 transition duration-300">
          <a href="#timeline" class="mobile-nav-link">Timeline</a>
        </li>
        <li class="mobile-nav-item text-center py-3 transition duration-300">
          <a href="#skills" class="mobile-nav-link">Skills</a>
        </li>
        <li class="mobile-nav-item text-center py-3 transition duration-300">
          <a href="#projects" class="mobile-nav-link">Selected Cases</a>
        </li>
        <li class="mobile-nav-item_last text-center py-3 transition duration-300">
          <a href="#contact" class="mobile-nav-link">Contact</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  [x-cloak] {
    display: none !important;
  }

  .nav-link {
    position: relative;
    padding: 0.5rem 0;
  }

  .mobile-nav-link {
    position: relative;
    display: inline-block;
    padding: 0.35rem 0;
    transition: color 0.25s ease;
  }

  .nav-link::after,
  .mobile-nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--brand-primary-soft);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease-in-out;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .mobile-nav-link:hover,
  .mobile-nav-link:focus-visible {
    color: var(--brand-primary-soft);
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .mobile-nav-link:hover::after,
  .mobile-nav-link:focus-visible::after {
    transform-origin: left;
    transform: scaleX(1);
  }

  .burger-icon:hover,
  .burger-icon:focus-visible {
    color: var(--brand-primary-soft);
  }

  .mobile-nav-item {
    border-bottom: 1px solid color-mix(in srgb, var(--brand-primary-soft) 20%, transparent);
  }

  .mobile-nav-item_last {
    border-bottom: none;
  }

  /* Border-only header treatment for the dark background */
  #header {
    background-color: var(--dark-bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(123, 123, 123, 0.24);
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease;
    font-size: 16px;
  }

  #header.header-scrolled {
    background-color: rgba(26, 26, 26, 0.96);
    border-bottom-color: rgba(163, 163, 163, 0.34);
  }
</style>

<script>
  const header = document.getElementById("header");
  const updateHeaderStyle = () => {
    if (window.scrollY > 10) {
      header?.classList.add("header-scrolled");
    } else {
      header?.classList.remove("header-scrolled");
    }
  };
  window.addEventListener("scroll", updateHeaderStyle, { passive: true });
  updateHeaderStyle();
</script>
