---
interface Props {
  href: string;
  image: string;
  alt: string;
  period: string;
  title: string;
  tools: string[];
}

const { href, image, alt, period, title, tools } = Astro.props;
---

<div class="case-card relative overflow-hidden group h-[300px]">
  <a href={href} target="_blank" rel="noopener noreferrer" class="case-link block w-full h-full" aria-label={`Open case: ${title} (opens in a new tab)`}>
    <img src={image} alt={alt} class="case-image w-full h-full object-cover" loading="lazy" decoding="async" />
    <div class="case-overlay absolute inset-0 opacity-0">
      <div class="absolute bottom-0 left-0 right-0 p-4 md:p-6">
        <p class="case-period" title={period}>{period}</p>
        <h4>{title}</h4>
        <div class="case-tools flex flex-wrap">
          {tools.map((tool) => <span title={tool}>{tool}</span>)}
        </div>
      </div>
    </div>
  </a>
</div>
