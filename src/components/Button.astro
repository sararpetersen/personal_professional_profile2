---
interface Props {
  href?: string;
}

const { href = "/pdfs/CV_sararpetersen_(DA).pdf" } = Astro.props as Props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="btn-primary relative z-[1] transition-colors duration-300 font-bold uppercase rounded-s tracking-wide px-6 py-3 md:px-8 md:py-4 text-center inline-flex items-center justify-center me-2 mb-2"
>
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 md:size-6 mr-2">
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13"
    ></path>
  </svg>
  <slot />
</a>

<style>
  .btn-primary {
    position: relative;
    overflow: hidden;
    border: 2px solid var(--brand-primary-soft);
    background: var(--brand-primary-soft);
    color: var(--dark-surface-strong);
  }

  .btn-primary:hover {
    border-color: var(--brand-primary-strong);
    background: var(--brand-primary-strong);
  }

  .btn-primary:focus-visible {
    outline: 2px solid var(--vermilion);
    outline-offset: 4px;
  }

  .btn-primary::before {
    content: "";
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: 0.4rem;
    height: 2px;
    border-radius: 9999px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--vermilion) 88%, transparent), transparent);
    opacity: 0.7;
    transform: scaleX(0.45);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .btn-primary:hover::before,
  .btn-primary:focus-visible::before {
    opacity: 1;
    transform: scaleX(1);
  }
</style>
