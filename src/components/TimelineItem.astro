---
interface Props {
  category: "School" | "Work";
  period: string;
  titleLines: string[];
  description: string;
}

const { category, period, titleLines, description } = Astro.props;
const categoryClass = `timeline-card-${category.toLowerCase()}`;
---

<li class={`timeline-card ${categoryClass}`}>
  <div class="timeline-card-meta">
    <p class="timeline-period mb-1 block text-[11px] font-semibold uppercase tracking-widest">{period}</p>
    <span class={`timeline-category timeline-category-${category.toLowerCase()}`}>{category}</span>
  </div>
  <h5 class="timeline-title mb-1 text-[15px] font-bold leading-snug">
    {
      titleLines.map((line, index) => (
        <>
          {index > 0 && <br class="md:hidden block" />}
          {index > 0 && " "}
          {line}
        </>
      ))
    }
  </h5>
  <p class="timeline-description pt-2 text-sm leading-relaxed">{description}</p>
</li>
