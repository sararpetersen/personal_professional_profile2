      (() => {
        try {
          const root = document.documentElement;
          if (localStorage.getItem("largeTextEnabled") === "true") root.classList.add("text-large");
          if (localStorage.getItem("readableFontEnabled") === "true") root.classList.add("readable-font");

          const applyBodyClasses = () => {
            const bodyClassMap = [
              ["reduceMotionEnabled", "reduce-motion"],
              ["calmModeEnabled", "calm-mode"],
              ["focusModeEnabled", "focus-mode"],
            ];

            bodyClassMap.forEach(([key, className]) => {
              if (localStorage.getItem(key) === "true") document.body.classList.add(className);
            });
          };

          if (document.body) applyBodyClasses();
          else document.addEventListener("DOMContentLoaded", applyBodyClasses, { once: true });
        } catch {
          /* Preferences are progressive enhancement. */
        }
      })();
    </script>
  </head>
